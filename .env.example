# Database — PostgreSQL + pgvector (only external service needed)
DATABASE_URL=postgresql://user:pass@localhost:5432/learnflow

# Ollama — local LLM, no API key required
# Make sure Ollama is running: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2              # or: mistral, qwen2.5, gemma2, etc.
OLLAMA_EMBED_MODEL=nomic-embed-text  # 768-dim embeddings

# LangSmith observability (optional — comment out to disable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=learnflow

# App ports
FASTAPI_PORT=8000
STREAMLIT_PORT=8501
