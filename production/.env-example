# ── LLM Provider ─────────────────────────────────────────────
# Options: "groq" (default, cloud) or "ollama" (local)
LLM_PROVIDER=groq

# Groq API — get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (only needed if LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3.2:1b

# ── Email (Brevo API — free tier: 300 emails/day) ────────────
# Sign up at https://app.brevo.com → SMTP & API → API Keys tab → Generate a new key
SENDER_EMAIL=your_verified_sender_email
BREVO_API_KEY=your_brevo_api_key

# ── Optional: Custom Colab API endpoint ──────────────────────
# Leave empty to use Groq exclusively
COLAB_API_URL=
