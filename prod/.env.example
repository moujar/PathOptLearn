# Copy to .env and adjust values before running docker compose up

# PostgreSQL — matches docker-compose defaults, change in production
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pathoptlearn
POSTGRES_USER=pathoptlearn
POSTGRES_PASSWORD=pathoptlearn

# Neo4j — password must match NEO4J_AUTH in docker-compose
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASS=pathoptlearn

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
